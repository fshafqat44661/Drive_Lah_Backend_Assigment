{
  "name": "settlement-service",
  "version": "1.0.0",
  "description": "Booking settlement service with idempotency and retry logic",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "start:mock": "ts-node src/mock-gateway/server.ts",
    "start:all": "concurrently \"npm run start:mock\" \"npm run dev\"",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "concurrently": "^8.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.0.0",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
